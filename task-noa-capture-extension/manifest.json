{
  "manifest_version": 3,
  "name": "Task-Noa Capture PoC",
  "version": "0.1.0",
  "description": "Capture visible Task-Noa business data and send normalized AI Native JSON to a local backend.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Capture visible business data",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
